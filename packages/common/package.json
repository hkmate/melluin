{
    "name": "@melluin/common",
    "version": "1.0.1",
    "private": true,
    "scripts": {
        "build": "tsc --project tsconfig.esm.json && tsc --project tsconfig.cjs.json",
        "clean": "rimraf dist node_modules",
        "clean:only-dist": "rimraf dist",
        "prepare": "pnpm run build",
        "dev": "tsc --watch --project tsconfig.esm.json & tsc --watch --project tsconfig.cjs.json",
        "test": "jest",
        "lint": "eslint"
    },
    "main": "./dist/esm/index.js",
    "types": "dist/types/index.d.ts",
    "exports": {
        "require": "./dist/cjs/index.js",
        "import": "./dist/esm/index.js",
        "types": "./dist/types/index.d.ts"
    },
    "dependencies": {
        "dayjs": "1.11.19",
        "lodash": "4.17.23",
        "rxjs": "7.8.2",
        "tslib": "2.8.1"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@types/jest": "30.0.0",
        "@types/jest-when": "3.5.5",
        "@types/lodash": "4.17.23",
        "@typescript-eslint/eslint-plugin": "8.56.0",
        "eslint": "10.0.1",
        "jest": "30.2.0",
        "jest-when": "3.7.0",
        "ts-jest": "29.4.6",
        "ts-node": "10.9.2",
        "typescript": "5.9.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}

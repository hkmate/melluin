{
    "name": "@melluin/common",
    "version": "1.0.1",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "private": true,
    "scripts": {
        "build": "tsc",
        "prepare": "pnpm run build",
        "dev": "tsc --watch",
        "test": "jest",
        "lint": "eslint"
    },
    "dependencies": {
        "dayjs": "1.11.13",
        "jwt-decode": "4.0.0",
        "lodash": "4.17.21",
        "rxjs": "7.8.1",
        "tslib": "2.6.3"
    },
    "devDependencies": {
        "@eslint/js": "9.9.0",
        "@types/jest": "29.5.12",
        "@types/jest-when": "3.5.5",
        "@types/lodash": "4.17.7",
        "eslint": "9.9.0",
        "eslint-plugin-max-params-no-constructor": "0.0.4",
        "jest": "29.7.0",
        "jest-when": "3.6.0",
        "ts-jest": "29.2.4",
        "ts-node": "10.9.2",
        "typescript": "5.5.4"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}

{
    "extends": "../../tsconfig.json",
    "include": [
        "src/**/*.ts"
    ],
    "compilerOptions": {
        "module": "commonjs",
        "declaration": true,
        "target": "es2017",
        "outDir": "./dist",
        "baseUrl": "./",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "paths": {
            "@resources/*": ["resources/*"],
            "@be/*": ["src/*"]
        }
    }
}

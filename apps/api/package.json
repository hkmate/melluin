        "@nestjs/jwt": "11.0.2",
        "@nestjs/passport": "11.0.5",
        "@nestjs/platform-express": "11.1.14",
        "@nestjs/swagger": "11.2.6",
        "@nestjs/throttler": "6.5.0",
        "@nestjs/typeorm": "11.0.0",
        "bcrypt": "6.0.0",
        "class-transformer": "0.5.1",
        "class-validator": "0.15.1",
        "dayjs": "1.11.19",
        "helmet": "8.1.0",
        "lodash": "4.17.23",
        "nestjs-typeorm-paginate": "4.1.0",
        "node-flywaydb": "3.0.7",
        "passport": "0.7.0",

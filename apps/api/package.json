{
    "name": "@melluin/api",
    "version": "1.0.1",
    "private": true,
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "nest build",
        "clean": "rimraf dist node_modules coverage",
        "migrate": "flyway -c resources/db/flyway-config.js migrate; rimraf report.json report.html",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/src/main",
        "lint": "eslint",
        "test": "vitest --run",
        "test:watch": "vitest --watch",
        "test:cov": "vitest --coverage --run"
    },
    "dependencies": {
        "@melluin/common": "link:../../packages/common",
